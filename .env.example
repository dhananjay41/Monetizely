# PostgreSQL connection string.
#
# Local development (see docker-compose.yml in this folder):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5433/monetizely?schema=public"
#
# On Vercel, provision a Postgres database (Vercel Postgres / Neon) and set
# DATABASE_URL in the project's Environment Variables. Use the *pooled*
# connection string for the app runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/monetizely?schema=public"
